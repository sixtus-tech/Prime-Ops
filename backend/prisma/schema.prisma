// ═══════════════════════════════════════════════════════════════════════
// Prime Ops Platform — PostgreSQL Schema (Supabase)
// Migration from SQLite → PostgreSQL
// ═══════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ───────────────────────────────────────────────────────────
model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String?
  name        String
  username    String?   @unique
  role        String    @default("user")
  globalRole  String    @default("user")
  avatarUrl   String?
  kcId        String?   @unique
  kcUsername  String?
  kcAccessToken    String?
  kcRefreshToken   String?
  kcTokenExpiresAt DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  notifications Notification[]
  members       Member[]
  auditLogs     AuditLog[]
  createdEvents Event[]        @relation("EventCreator")

  @@index([email])
  @@index([kcId])
}

// ─── Events (will rename to Program in Phase 4) ─────────────────────
model Event {
  id                  String    @id @default(uuid())
  title               String
  subtitle            String?
  description         String?
  summary             String?
  eventType           String    @default("general")
  startDate           DateTime?
  endDate             DateTime?
  venue               String?
  estimatedBudget     String?
  estimatedAttendance String?
  status              String    @default("draft")
  createdById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createdBy        User?             @relation("EventCreator", fields: [createdById], references: [id])
  committees       Committee[]
  scheduledBroadcasts ScheduledBroadcast[]
  proposals        Proposal[]
  milestones       Milestone[]
  activities       Activity[]
  tasks            Task[]
  approvalRequests ApprovalRequest[]

  @@index([createdById])
  @@index([status])
}

// ─── Committees ──────────────────────────────────────────────────────
model Committee {
  id               String    @id @default(uuid())
  eventId          String
  name             String
  description      String?
  proposalDeadline DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members          Member[]
  responsibilities Responsibility[]
  proposals        Proposal[]
  statusUpdates    StatusUpdate[]
  subMilestones    SubMilestone[]
  approvalRequests ApprovalRequest[]
  proposalComments ProposalComment[]
  fileUploads      FileUpload[]

  @@index([eventId])
}

// ─── Members ─────────────────────────────────────────────────────────
model Member {
  id          String   @id @default(uuid())
  committeeId String
  userId      String?
  kcId        String?
  kcUsername  String?
  name        String
  email       String?
  phone       String?
  role        String   @default("member")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@unique([committeeId, userId])
  @@index([userId])
  @@index([committeeId])
}

// ─── Responsibilities ────────────────────────────────────────────────
model Responsibility {
  id          String   @id @default(uuid())
  committeeId String
  text        String
  createdAt   DateTime @default(now())

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@index([committeeId])
}

// ─── Proposals ───────────────────────────────────────────────────────
model Proposal {
  id           String   @id @default(uuid())
  eventId      String?
  committeeId  String?
  inputText    String?  @db.Text
  inputType    String   @default("text")
  proposalJson String   @db.Text
  status       String   @default("draft")
  submittedBy  String?
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event     Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  committee Committee?        @relation(fields: [committeeId], references: [id], onDelete: SetNull)
  comments  ProposalComment[]

  @@index([committeeId])
  @@index([eventId])
  @@index([status])
}

// ─── Proposal Comments ───────────────────────────────────────────────
model ProposalComment {
  id          String   @id @default(uuid())
  proposalId  String
  committeeId String
  authorId    String?
  authorName  String
  authorRole  String
  content     String   @db.Text
  status      String   @default("visible")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposal  Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([committeeId])
}

// ─── Approval Requests ───────────────────────────────────────────────
model ApprovalRequest {
  id          String    @id @default(uuid())
  eventId     String
  committeeId String?
  proposalId  String?
  title       String
  description String?   @db.Text
  requestedBy String
  priority    String    @default("normal")
  status      String    @default("pending")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  committee Committee?       @relation(fields: [committeeId], references: [id])
  actions   ApprovalAction[]

  @@index([eventId])
  @@index([status])
}

// ─── Approval Actions ────────────────────────────────────────────────
model ApprovalAction {
  id                String   @id @default(uuid())
  approvalRequestId String
  action            String
  performedBy       String
  comment           String?  @db.Text
  createdAt         DateTime @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
}

// ─── Milestones ──────────────────────────────────────────────────────
model Milestone {
  id               String    @id @default(uuid())
  eventId          String
  title            String
  description      String?   @db.Text
  phase            Int
  targetDate       DateTime?
  status           String    @default("not_started")
  progress         Int       @default(0)
  requiresApproval Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subMilestones SubMilestone[]

  @@index([eventId])
  @@index([phase])
}

// ─── Sub-Milestones ──────────────────────────────────────────────────
model SubMilestone {
  id               String    @id @default(uuid())
  milestoneId      String
  committeeId      String
  title            String
  description      String?   @db.Text
  sortOrder        Int       @default(0)
  status           String    @default("not_started")
  requiresApproval Boolean   @default(false)
  completedAt      DateTime?
  completedBy      String?
  approvedAt       DateTime?
  approvedBy       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  milestone     Milestone      @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  committee     Committee      @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  statusUpdates StatusUpdate[] @relation("MilestoneEvidence")

  @@index([milestoneId])
  @@index([committeeId])
  @@index([status])
}

// ─── Status Updates ──────────────────────────────────────────────────
model StatusUpdate {
  id             String   @id @default(uuid())
  committeeId    String
  eventId        String?
  subMilestoneId String?
  title          String
  summary        String?  @db.Text
  progress       Int?     @default(0)
  evidenceSummary Json?
  content        String?  @db.Text
  status         String   @default("on_track")
  highlights     Json?
  challenges     Json?
  nextSteps      Json?
  metrics        Json?
  media          Json?
  submittedBy    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  committee    Committee     @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  subMilestone SubMilestone? @relation("MilestoneEvidence", fields: [subMilestoneId], references: [id])

  @@index([committeeId])
  @@index([eventId])
  @@index([subMilestoneId])
  @@index([createdAt])
}

// ─── Tasks ───────────────────────────────────────────────────────────
model Task {
  id          String    @id @default(uuid())
  eventId     String
  committeeId String?
  title       String
  description String?   @db.Text
  assignedTo  String?
  priority    String    @default("medium")
  status      String    @default("pending")
  dueDate     DateTime?
  completedAt DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([committeeId])
  @@index([status])
}

// ─── Notifications ───────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String   @db.Text
  link      String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Activity Log ────────────────────────────────────────────────────
model Activity {
  id          String   @id @default(uuid())
  eventId     String?
  action      String
  description String   @db.Text
  performedBy String
  createdAt   DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdAt])
}

// ─── Audit Log (immutable) ───────────────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  programId  String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([programId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── File Uploads ────────────────────────────────────────────────────
model FileUpload {
  id          String   @id @default(uuid())
  committeeId String?
  programId   String?
  uploadedBy  String
  fileName    String
  storagePath String
  mimeType    String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  committee Committee? @relation(fields: [committeeId], references: [id])

  @@index([committeeId])
  @@index([programId])
}

model ScheduledBroadcast {
  id            String   @id @default(uuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subject       String?
  message       String
  urgency       String   @default("normal")
  committeeIds  Json?
  scheduledFor  DateTime
  sent          Boolean  @default(false)
  sentAt        DateTime?
  createdBy     String?
  createdAt     DateTime @default(now())

  @@index([scheduledFor, sent])
}
